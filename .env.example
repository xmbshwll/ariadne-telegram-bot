# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Bot log level: debug, info, warn, error
LOG_LEVEL=info

# Optional health endpoint port. When unset, probe server stays disabled.
# Cloud Run sets PORT automatically.
# PORT=8080

# Ariadne runtime configuration.
# Spotify target search needs both credentials.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Default Apple Music storefront when URL does not imply one.
APPLE_MUSIC_STOREFRONT=us

# Optional Apple Music MusicKit credentials for identifier search.
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=

# Preferred for Docker/Kubernetes/secret-file mounts.
APPLE_MUSIC_PRIVATE_KEY_PATH=

# Optional inline secret variants. If APPLE_MUSIC_PRIVATE_KEY_PATH is empty,
# bot writes one of these into temp AuthKey.p8 file at startup and points
# APPLE_MUSIC_PRIVATE_KEY_PATH to it automatically.
# APPLE_MUSIC_PRIVATE_KEY=
# APPLE_MUSIC_PRIVATE_KEY_BASE64=

# Optional TIDAL credentials.
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# Optional Ariadne tuning.
ARIADNE_HTTP_TIMEOUT=15s
# ARIADNE_TARGET_SERVICES=spotify,appleMusic,bandcamp,youtubeMusic
